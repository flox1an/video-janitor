# Database connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_janitor

# Source relays: file-based (recommended for large lists) or comma-separated inline
# SOURCE_RELAYS_FILE=/path/to/relays.txt
SOURCE_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# Target relays for event forwarding (comma-separated)
# TARGET_RELAYS takes precedence when set; TARGET_RELAY is kept for backward compatibility.
TARGET_RELAYS=wss://localhost:7777
# TARGET_RELAY=wss://localhost:7777

# Job configuration
JOB_INTERVAL_HOURS=1
URL_CHECK_CONCURRENCY=10
URL_CHECK_TIMEOUT_SECS=10
URL_CHECK_DELAY_MS=100

# Backfill limits (safety limits for initial sync)
BACKFILL_BATCH_SIZE=500
BACKFILL_MAX_EVENTS=10000

# Logging (optional, default: info)
RUST_LOG=info
